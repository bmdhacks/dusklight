+        if (hasClamp) {
+            DAWN_GL_TRY(gl, PolygonOffsetClamp(factor, units, clamp));
+        } else {
+            DAWN_GL_TRY(gl, PolygonOffset(factor, units));
+        }
+        mPolygonOffsetFactor = factor;
+        mPolygonOffsetUnits = units;
+        mPolygonOffsetClamp = clamp;
+    }
+    return {};
+}
+
+MaybeError PersistentPipelineState::SetBlendState(const OpenGLFunctions& gl,
+                                                  GLuint target,
+                                                  bool enabled,
+                                                  GLenum colorEquation,
+                                                  GLenum alphaEquation,
+                                                  GLenum srcColorFactor,
+                                                  GLenum dstColorFactor,
+                                                  GLenum srcAlphaFactor,
+                                                  GLenum dstAlphaFactor) {
+    DAWN_ASSERT(target < kMaxShadowColorTargets);
+    BlendShadow& s = mBlend[target];
+    if (!mDynamicStateValid || s.enabled != enabled) {
+        if (enabled) {
+            DAWN_GL_TRY(gl, Enablei(GL_BLEND, target));
+        } else {
+            DAWN_GL_TRY(gl, Disablei(GL_BLEND, target));
+        }
+        s.enabled = enabled;
+    }
+    if (enabled) {
+        if (!mDynamicStateValid || s.colorEquation != colorEquation ||
+            s.alphaEquation != alphaEquation) {
+            DAWN_GL_TRY(gl, BlendEquationSeparatei(target, colorEquation, alphaEquation));
+            s.colorEquation = colorEquation;
+            s.alphaEquation = alphaEquation;
+        }
+        if (!mDynamicStateValid || s.srcColorFactor != srcColorFactor ||
+            s.dstColorFactor != dstColorFactor || s.srcAlphaFactor != srcAlphaFactor ||
+            s.dstAlphaFactor != dstAlphaFactor) {
+            DAWN_GL_TRY(gl, BlendFuncSeparatei(target, srcColorFactor, dstColorFactor,
+                                               srcAlphaFactor, dstAlphaFactor));
+            s.srcColorFactor = srcColorFactor;
+            s.dstColorFactor = dstColorFactor;
+            s.srcAlphaFactor = srcAlphaFactor;
+            s.dstAlphaFactor = dstAlphaFactor;
+        }
+    }
+    return {};
+}
+
+MaybeError PersistentPipelineState::SetColorMask(const OpenGLFunctions& gl,
+                                                 GLuint target,
+                                                 bool red,
+                                                 bool green,
+                                                 bool blue,
+                                                 bool alpha) {
+    DAWN_ASSERT(target < kMaxShadowColorTargets);
+    ColorMaskShadow& m = mColorMask[target];
+    if (!mDynamicStateValid || m.red != red || m.green != green || m.blue != blue ||
+        m.alpha != alpha) {
+        DAWN_GL_TRY(gl, ColorMaski(target, red, green, blue, alpha));
+        m = {red, green, blue, alpha};
+    }
+    return {};
+}
