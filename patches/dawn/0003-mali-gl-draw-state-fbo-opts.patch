+// Dusklight (P1d): render-pass FBO cache. See FramebufferCacheKey / DeviceGL.h for the ordering
+// argument that makes handle-keyed caching safe.
+GLuint Device::LookupFramebuffer(const FramebufferCacheKey& key) const {
+    auto it = mFramebufferCache.find(key);
+    return it == mFramebufferCache.end() ? 0 : it->second;
+}
+
+void Device::StoreFramebuffer(const FramebufferCacheKey& key, GLuint fbo) {
+    mFramebufferCache.emplace(key, fbo);
+}
+
+void Device::EvictFramebuffersReferencing(const OpenGLFunctions& gl, GLuint textureHandle) {
+    // Delete matching FBOs while scanning, collect their keys, then erase (this abseil's
+    // flat_hash_map::erase returns void, so we can't erase-and-advance in one step).
+    std::vector<FramebufferCacheKey> toErase;
+    for (const auto& [key, fbo] : mFramebufferCache) {
+        for (const auto& slot : key.slots) {
+            if (slot.handle == textureHandle) {
+                GLuint f = fbo;
+                DAWN_GL_TRY_IGNORE_ERRORS(gl, DeleteFramebuffers(1, &f));
+                toErase.push_back(key);
+                break;
+            }
+        }
+    }
+    for (const auto& key : toErase) {
+        mFramebufferCache.erase(key);
+    }
+}
