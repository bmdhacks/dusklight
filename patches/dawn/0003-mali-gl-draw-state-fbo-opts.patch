 namespace dawn::native::opengl {
 
+// Dusklight (P1d): render-pass FBO cache key. Aurora issues ~21 render passes/frame and Dawn's GL
+// backend otherwise gen/attach/DeleteFramebuffers on every one — a large per-frame driver cost on
+// Mali. The attachment set (which texture images, at which subresource, in which slot) fully
+// determines the FBO, and it is stable frame-to-frame, so keying on it lets a pass reuse one FBO.
+// Entries are evicted when any attached texture handle is destroyed
+// (Device::EvictFramebuffersReferencing); because texture deletes and render-pass execution run on
+// the one serialized GL work list, that eviction is ordered before the handle can be recycled, so
+// no stale FBO can ever be handed back for a reused handle.
+struct FramebufferCacheKey {
+    struct Slot {
+        GLuint handle = 0;   // GL texture name attached at this slot (0 = slot unused)
+        GLenum target = 0;   // GL texture target used for the attach
+        GLuint level = 0;    // mip level
+        GLuint layer = 0;    // array layer (+ depthSlice for 3D RTVs)
+        bool operator==(const Slot&) const = default;
+    };
+    // slots[0 .. kMaxColorAttachments-1] = color attachments by index;
+    // slots[kMaxColorAttachments]        = depth/stencil attachment.
+    std::array<Slot, kMaxColorAttachments + 1> slots{};
+    uint32_t colorMask = 0;   // which color slots are attached (drives glDrawBuffers config)
+    bool hasDepth = false;
+    bool operator==(const FramebufferCacheKey&) const = default;
+
+    template <typename H>
+    friend H AbslHashValue(H h, const FramebufferCacheKey& k) {
+        for (const auto& s : k.slots) {
+            h = H::combine(std::move(h), s.handle, s.target, s.level, s.layer);
+        }
+        return H::combine(std::move(h), k.colorMask, k.hasDepth);
+    }
+};
