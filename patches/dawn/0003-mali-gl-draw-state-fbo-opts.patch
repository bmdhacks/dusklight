+MaybeError PersistentPipelineState::SetPolygonOffset(const OpenGLFunctions& gl,
+                                                     bool enabled,
+                                                     float factor,
+                                                     float units,
+                                                     float clamp,
+                                                     bool hasClamp) {
+    if (!mDynamicStateValid || mPolygonOffsetEnabled != enabled) {
+        if (enabled) {
+            DAWN_GL_TRY(gl, Enable(GL_POLYGON_OFFSET_FILL));
+        } else {
+            DAWN_GL_TRY(gl, Disable(GL_POLYGON_OFFSET_FILL));
