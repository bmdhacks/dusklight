 namespace dawn::native::opengl {
 
+namespace {
+
+struct PortmasterSdl2ShimEglSurface {
+    uint32_t magic;
+    uint32_t version;
+    void* eglDisplay;
+    void* eglSurface;
+    void* sdl2Window;
+    void* sdl2Context;
+    void* glGetProc;
+    void* glMakeCurrent;
+    void* glSwapWindow;
+    void* eglMakeCurrent;
+    void* eglContext;
+    uint32_t flags;
+    uint32_t drawableWidth;
+    uint32_t drawableHeight;
+    uint32_t reserved;
+};
+
+constexpr uint32_t PortmasterSdl2ShimEglSurfaceMagic = 0x44533245;  // DS2E
+constexpr uint32_t PortmasterSdl2ShimEglSurfaceVersion = 2;
+constexpr uint32_t PortmasterSdl2ShimFlagDawnContextPresent = 1u << 2;
+uintptr_t PortmasterParsePointerEnv(const char* name) {
+    const char* value = std::getenv(name);
+    if (value == nullptr || value[0] == '\0') {
+        return 0;
+    }
+    return static_cast<uintptr_t>(std::strtoull(value, nullptr, 0));
+}
+
+bool PortmasterIsValidSdl2ShimSurface(PortmasterSdl2ShimEglSurface* info) {
+    return info != nullptr && info->magic == PortmasterSdl2ShimEglSurfaceMagic &&
+           info->version >= 1 && info->version <= PortmasterSdl2ShimEglSurfaceVersion &&
+           info->eglSurface != nullptr;
+}
+
+bool PortmasterSdl2ShimSwapPresentEnabled() {
+    const char* value = std::getenv("DUSKLIGHT_PORTMASTER_SDL2SHIM_SWAP_PRESENT");
+    return value == nullptr || (value[0] != '\0' && value[0] != '0');
+}
+
+bool PortmasterSdl2ShimDawnContextPresent(PortmasterSdl2ShimEglSurface* info) {
+    return info != nullptr && (info->flags & PortmasterSdl2ShimFlagDawnContextPresent) != 0;
+}
+
+EGLint PortmasterSdl2ShimWidthOrDefault(PortmasterSdl2ShimEglSurface* info, uint32_t fallback) {
+    if (info != nullptr && info->version >= 2 && info->drawableWidth > 0) {
+        return static_cast<EGLint>(info->drawableWidth);
+    }
+    return static_cast<EGLint>(fallback);
+}
+
+EGLint PortmasterSdl2ShimHeightOrDefault(PortmasterSdl2ShimEglSurface* info, uint32_t fallback) {
+    if (info != nullptr && info->version >= 2 && info->drawableHeight > 0) {
+        return static_cast<EGLint>(info->drawableHeight);
+    }
+    return static_cast<EGLint>(fallback);
+}
+
+EGLDisplay PortmasterSdl2ShimDisplayOrDefault(PortmasterSdl2ShimEglSurface* info,
+                                              EGLDisplay fallback) {
+    if (info != nullptr && info->eglDisplay != nullptr) {
+        return reinterpret_cast<EGLDisplay>(info->eglDisplay);
+    }
+    return fallback;
+}
+
+PortmasterSdl2ShimEglSurface* PortmasterGetSdl2ShimSurface(Surface* surface) {
+    if (std::getenv("DUSKLIGHT_PORTMASTER_SDL2SHIM_EGL_SURFACE") == nullptr) {
+        return nullptr;
+    }
+    auto* info = reinterpret_cast<PortmasterSdl2ShimEglSurface*>(
+        PortmasterParsePointerEnv("DUSKLIGHT_PORTMASTER_SDL2SHIM_EGL_SURFACE_INFO"));
+    if (PortmasterIsValidSdl2ShimSurface(info)) {
+        return info;
+    }
+    if (surface->GetType() != Surface::Type::XlibWindow || surface->GetXDisplay() != nullptr ||
+        surface->GetXWindow() == 0) {
+        return nullptr;
+    }
+    info = reinterpret_cast<PortmasterSdl2ShimEglSurface*>(static_cast<uintptr_t>(surface->GetXWindow()));
+    if (!PortmasterIsValidSdl2ShimSurface(info)) {
+        return nullptr;
+    }
+    return info;
+}
+
+bool PortmasterMakeCurrentSdl2Shim(PortmasterSdl2ShimEglSurface* info) {
+    if (info == nullptr) {
+        return false;
+    }
+    using MakeCurrentFn = int (*)(void*, void*);
+    using EglMakeCurrentFn = unsigned int (*)(void*, void*, void*, void*);
+    void* eglContext = info->version >= 2 && info->eglContext != nullptr ? info->eglContext : info->sdl2Context;
+    if (info->glMakeCurrent != nullptr && info->sdl2Window != nullptr && info->sdl2Context != nullptr) {
+        if (reinterpret_cast<MakeCurrentFn>(info->glMakeCurrent)(info->sdl2Window, info->sdl2Context) != 0) {
+            return false;
+        }
+        return true;
+    }
+    if (info->eglMakeCurrent != nullptr && info->eglDisplay != nullptr && info->eglSurface != nullptr &&
+        eglContext != nullptr) {
+        if (!reinterpret_cast<EglMakeCurrentFn>(info->eglMakeCurrent)(info->eglDisplay, info->eglSurface,
+                                                                      info->eglSurface, eglContext)) {
+            return false;
+        }
+    }
+    return true;
+}
+
+bool PortmasterPresentSdl2Shim(PortmasterSdl2ShimEglSurface* info) {
+    if (info == nullptr || !PortmasterSdl2ShimSwapPresentEnabled()) {
+        return false;
+    }
+    using SwapWindowFn = void (*)(void*);
+    if (!PortmasterSdl2ShimDawnContextPresent(info) && !PortmasterMakeCurrentSdl2Shim(info)) {
+        return false;
+    }
+    if (info->glSwapWindow == nullptr || info->sdl2Window == nullptr) {
+        return false;
+    }
+    reinterpret_cast<SwapWindowFn>(info->glSwapWindow)(info->sdl2Window);
+    return true;
+}
+
