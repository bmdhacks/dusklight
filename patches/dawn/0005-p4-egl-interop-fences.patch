@@ -84,6 +84,30 @@
 DAWN_NATIVE_EXPORT WGPUTexture
 WrapExternalGLTexture(WGPUDevice device, const ExternalImageDescriptorGLTexture* descriptor);
 
+// Dusklight (P4): cross-context fences for the SDL2-shim EFB present path.
+//
+// On Mali the render worker owns Dawn's EGL context (game render + Submit) while the main thread
+// keeps the firmware's borrowed context current and blits the finished frame to the window. Those
+// are two *different* EGL contexts sharing textures via EGLImage, so the GPU work has to be ordered
+// explicitly with EGL fences. Aurora can create/wait fences in the shim context itself, but it has
+// no way to do so in Dawn's context: eglCreateSync/eglWaitSync need that context current, and Dawn
+// releases it as soon as a scoped make-current ends. These hooks run the EGL call inside
+// Device::EnqueueAndFlushGL, i.e. under Dawn's exclusive make-current mutex, which is the only safe
+// way in.
+//
+// The returned handle is a raw EGLSync owned by the caller; release it with PortmasterDestroyEGLSync.
+
+// Insert a fence into Dawn's context after the frame's commands and flush so another context can
+// wait on it. Returns nullptr on failure.
+DAWN_NATIVE_EXPORT void* PortmasterCreateFrameEGLSync(WGPUDevice device);
+
+// Make Dawn's context wait (server-side, non-blocking for the CPU) until `sync` signals. Commands
+// submitted afterwards will not run before it. A null `sync` is a no-op success.
+DAWN_NATIVE_EXPORT bool PortmasterServerWaitEGLSync(WGPUDevice device, void* sync);
+
+// Destroy a sync created by either context. Needs no current context.
+DAWN_NATIVE_EXPORT void PortmasterDestroyEGLSync(WGPUDevice device, void* sync);
+
 }  // namespace dawn::native::opengl
 
 #endif  // INCLUDE_DAWN_NATIVE_OPENGLBACKEND_H_
