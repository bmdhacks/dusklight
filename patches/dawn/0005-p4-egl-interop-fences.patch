+void* PortmasterCreateFrameEGLSync(WGPUDevice cDevice) {
+    Device* device = ToBackend(FromAPI(cDevice));
+    EGLSync sync = EGL_NO_SYNC;
+
+    // Passive: this fence tracks work the caller already submitted; it must not bump the queue's
+    // command serial or Dawn would wait on a submission that never happens.
+    MaybeError result = device->EnqueueAndFlushGL(
+        ExecutionQueueBase::SubmitMode::Passive,
+        [device, &sync](const OpenGLFunctions& gl) -> MaybeError {
+            DisplayEGL* display = GetDisplayEGL(device);
+            const EGLFunctions& egl = display->egl.get();
+
+            // EGL_KHR_fence_sync and the EGL 1.5 core entry point take incompatible attribute
+            // lists, so dispatch the same way WrappedEGLSync::Create does. We pass no attributes.
+            if (egl.HasExt(EGLExt::FenceSync)) {
+                sync = egl.CreateSyncKHR(display->GetDisplay(), EGL_SYNC_FENCE, nullptr);
+            } else {
+                sync = egl.CreateSync(display->GetDisplay(), EGL_SYNC_FENCE, nullptr);
+            }
+            DAWN_TRY(CheckEGL(egl, sync != EGL_NO_SYNC, "eglCreateSync"));
+
+            // A fence is only guaranteed to be visible to other contexts once it has been flushed
+            // to the driver. Nothing else flushes Dawn's context on this path.
+            DAWN_GL_TRY(gl, Flush());
+            return {};
+        });
+
+    if (device->ConsumedError(std::move(result))) {
+        return nullptr;
+    }
+    return sync;
+}
+
+bool PortmasterServerWaitEGLSync(WGPUDevice cDevice, void* sync) {
+    if (sync == nullptr) {
+        return true;
+    }
+    Device* device = ToBackend(FromAPI(cDevice));
+
+    MaybeError result = device->EnqueueAndFlushGL(
+        ExecutionQueueBase::SubmitMode::Passive,
+        [device, sync](const OpenGLFunctions& gl) -> MaybeError {
+            DisplayEGL* display = GetDisplayEGL(device);
+            const EGLFunctions& egl = display->egl.get();
+            constexpr EGLint flags = 0;
+            DAWN_TRY(CheckEGL(egl, egl.WaitSync(display->GetDisplay(), sync, flags), "eglWaitSync"));
+            return {};
+        });
+
+    return !device->ConsumedError(std::move(result));
+}
+
+void PortmasterDestroyEGLSync(WGPUDevice cDevice, void* sync) {
+    if (sync == nullptr) {
+        return;
+    }
+    Device* device = ToBackend(FromAPI(cDevice));
+    DisplayEGL* display = GetDisplayEGL(device);
+    const EGLFunctions& egl = display->egl.get();
+
+    // eglDestroySync is display-scoped: no context needs to be current, and any pending server
+    // waits keep the underlying object alive until they retire.
+    if (egl.HasExt(EGLExt::FenceSync)) {
+        egl.DestroySyncKHR(display->GetDisplay(), sync);
+    } else {
+        egl.DestroySync(display->GetDisplay(), sync);
+    }
+}
+
 }  // namespace dawn::native::opengl
